---
import MainLayout from '@/layouts/MainLayout.astro';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
import CardSmall from '@components/ui/cards/CardSmall.astro';
import CardWide from '@components/ui/cards/CardWide.astro';
import FeaturesStatsAlt from '@components/sections/features/FeaturesStatsAlt.astro';
import TestimonialsSectionAlt from '@components/sections/testimonials/TestimonialsSectionAlt.astro';

import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE } from '@data/constants';

const product: CollectionEntry<'products'>[] = (
  await getCollection('products', ({ id }) => {
    return id.startsWith('en/');
  })
).sort(
  (a: CollectionEntry<'products'>, b: CollectionEntry<'products'>) =>
    a.data.main.id - b.data.main.id
);

const title: string = 'La Bàn Cảm Xúc';
const subTitle: string =
  'Bộ thẻ giúp gọi tên, quan sát và điều hướng cảm xúc một cách rõ ràng hơn. Phù hợp cho cá nhân, nhóm học tập, workshop, facilitator và cộng đồng.';

const testimonials = [
  {
    content:
      ' "La Bàn Cảm Xúc giúp buổi check-in của nhóm trở nên thật hơn. Mọi người dễ nói về trạng thái của mình mà không bị ép phải giải thích quá nhiều." ',
    author: 'Minh Anh',
    role: 'Facilitator | Community Circle',
    avatarSrc:
      'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1374&auto=format&fit=crop&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
    avatarAlt: 'Community member avatar',
  },
  {
    content:
      ' "Bộ thẻ này làm việc rất tốt trong lớp học. Học viên có ngôn ngữ để nhận diện cảm xúc, từ đó chia sẻ nhẹ nhàng và sâu hơn." ',
    author: 'Hoang Lam',
    role: 'Educator | Creative Learning',
    avatarSrc:
      'https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=1376&auto=format&fit=crop&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
    avatarAlt: 'Educator avatar',
  },
  {
    content:
      ' "Mình dùng La Bàn Cảm Xúc để journaling mỗi tuần. Nó giúp mình nhìn ra mình đang cần gì, thay vì chỉ biết là mình đang rối." ',
    author: 'Bao Tran',
    role: 'Creative Builder | Folks Team',
    avatarSrc:
      'https://images.unsplash.com/photo-1474176857210-7287d38d27c6?q=80&w=1470&auto=format&fit=crop&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
    avatarAlt: 'Creative builder avatar',
  },
];

const pageTitle: string = `La Bàn Cảm Xúc | ${SITE.title}`;
const metaDescription =
  'La Bàn Cảm Xúc là bộ thẻ giúp nhận diện, gọi tên và điều hướng cảm xúc cho cá nhân, nhóm và workshop.';
const ogTitle = 'La Bàn Cảm Xúc | Folks Team';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://folksteam.com/products',
    url: 'https://folksteam.com/products',
    name: 'La Bàn Cảm Xúc | Folks Team',
    description:
      'Bộ thẻ giúp nhận diện, gọi tên và điều hướng cảm xúc cho cá nhân, nhóm và workshop.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://folksteam.com',
      name: 'FOLKS TEAM',
      description:
        'A strategic framework for building marketing, community, and scalable growth systems.',
    },
    inLanguage: 'en-US',
  }}
>
  <div
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <div class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12">
      <div class="flex items-center gap-12">
        <h1
          class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
        >
          {title}
        </h1>
        {
          subTitle && (
            <p class="hidden max-w-(--breakpoint-sm) text-pretty text-neutral-600 md:block dark:text-neutral-400">
              {subTitle}
            </p>
          )
        }
      </div>
      <PrimaryCTA title="Explore Stories" url="#testimonials" noArrow={true} />
    </div>

    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} />;
          } else {
            return <CardWide product={product} />;
          }
        })
      }
    </section>
  </div>

  <FeaturesStatsAlt
    title="Why Choose La Bàn Cảm Xúc?"
    subTitle="Biến cảm xúc thành ngôn ngữ để hiểu mình, giao tiếp tốt hơn và chọn hành động phù hợp hơn. Đây là một công cụ nhỏ, nhưng có thể mở ra những cuộc trò chuyện rất thật."
    benefits={[
      'Giúp gọi tên cảm xúc thay vì chỉ cảm thấy mơ hồ.',
      'Phù hợp cho cá nhân, lớp học, workshop và nhóm cộng đồng.',
      'Tạo cấu trúc an toàn để chia sẻ, lắng nghe và reflection.',
    ]}
  />

  <TestimonialsSectionAlt
    title="What Our Community Says"
    testimonials={testimonials}
  />
</MainLayout>
