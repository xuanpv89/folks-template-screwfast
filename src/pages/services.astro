---
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';
import { SITE } from '@data/constants';

import strategyImage from '@images/growth-brainstorm.jpg';
import workshopImage from '@images/growth-workshop.jpg';
import analyticsImage from '@images/growth-analytics.jpg';
import brandMark from '@images/folks-brand-mark.jpg';
import brandLogo from '@images/folks-brand-logo.png';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'C.H.E.S.S Strategy Consulting',
    subTitle:
      'We help you define positioning, audience, message, and growth direction before jumping into execution. The goal is to create a clear map so every marketing, content, and community activity moves in the same direction.',
    single: false,
    imgOne: strategyImage,
    imgOneAlt: 'Team mapping a structured growth strategy',
    imgTwo: brandMark,
    imgTwoAlt: 'Folks Team brand mark',
  },
  {
    isRightSection: false,
    title: 'Content Engine and Hub Design',
    subTitle:
      'From scattered ideas, we help you build a content engine, resource hub, and publishing workflow that turn content into a long-term growth asset.',
    img: workshopImage,
    imgAlt: 'Workshop for building a content system',
    btnExists: true,
    btnTitle: 'View products',
    btnURL: '/products',
  },
  {
    isRightSection: true,
    title: 'Community and Ecosystem Integration',
    subTitle:
      'Community is more than a place to post updates. We design interaction loops, touchpoints, feedback paths, and partner ecosystems so growth becomes deeper and more resilient.',
    single: false,
    imgOne: analyticsImage,
    imgOneAlt: 'Growth analytics dashboard',
    imgTwo: brandLogo,
    imgTwoAlt: 'Folks Team logo',
  },
  {
    isRightSection: false,
    title: 'Operations and Continuous Optimization',
    subTitle:
      'Once the system is live, we support measurement, review rhythms, workflow optimization, and priority adjustments based on data, feedback, and team capacity.',
    img: analyticsImage,
    imgAlt: 'Growth data and operating dashboard',
  },
  {
    isRightSection: true,
    title: 'Emotional Compass Workshops',
    subTitle:
      'For teams that need better communication and deeper understanding, we can design workshops using Emotional Compass to open safer, more specific, and more human conversations.',
    single: false,
    imgOne: brandMark,
    imgOneAlt: 'Folks Team color system',
    imgTwo: workshopImage,
    imgTwoAlt: 'Team workshop environment',
    btnExists: true,
    btnTitle: 'Contact us',
    btnURL: '/contact',
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'Folks Team provides C.H.E.S.S-based consulting and implementation services for growth strategy, content systems, community, operations, and Emotional Compass workshops.';
const ogTitle = 'C.H.E.S.S Growth Services | Folks Team';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://folksteam.com/services',
    url: 'https://folksteam.com/services',
    name: 'C.H.E.S.S Growth Services | Folks Team',
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://folksteam.com',
      name: 'Folks Team',
      description:
        'Folks Team builds modern growth systems based on C.H.E.S.S.',
    },
    inLanguage: 'en-US',
  }}
>
  <MainSection
    title="Turn Growth Into an Operating System"
    subTitle="Folks Team helps you connect strategy, content, community, and operations into a clear, practical, and scalable growth model built on C.H.E.S.S."
    btnExists={true}
    btnTitle="Start a Conversation"
    btnURL="/contact"
  />

  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }

  <FeaturesStats
    title="Growth by System"
    subTitle="Folks Team services focus on clarity, structure, and repeatability so teams do not have to depend on scattered tactics or short bursts of motivation."
    mainStatTitle="96%"
    mainStatSubTitle="of clients report stronger clarity after a strategy review"
    stats={[
      {
        stat: '5+',
        description: 'C.H.E.S.S layers connected into one system',
      },
      {
        stat: '24.8K',
        description: 'workflows and system templates created',
      },
      {
        stat: '132K',
        description: 'builders applying structured growth',
      },
    ]}
  />
</MainLayout>
