---
import LoginBtn from '@components/ui/buttons/LoginBtn.astro';

const locale = Astro.currentLocale;
const title =
  locale === 'vi' ? 'Thành viên' : locale === 'zh' ? '会员' : 'Member';
const url =
  locale === 'vi' ? '/vi/member' : locale === 'zh' ? '/zh/member' : '/member';
---

<LoginBtn title={title} url={url} />
